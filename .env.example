# Deliberate environment variables
# Copy to .env and fill in values

# Database
DATABASE_URL=postgresql+asyncpg://deliberate:deliberate@localhost:5432/deliberate

# Server — REQUIRED, no default
SECRET_KEY=
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=4000

# Deprecated fallback — use YAML policies in config/policies/ instead
# DEFAULT_APPROVER_EMAIL=approver@example.com

# UI URL for approval link construction
UI_URL=http://localhost:3000

# Slack (optional)
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# Email / SMTP (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@example.com
SMTP_FROM_NAME=Deliberate

# Webhook (optional)
WEBHOOK_SIGNING_SECRET=

# Worker
WORKER_POLL_INTERVAL_SECONDS=15
MAX_ESCALATION_DEPTH=3

# OTLP (optional — disabled by default)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# UI
NEXT_PUBLIC_API_URL=http://localhost:4000
INTERNAL_API_URL=http://server:4000

# SDK (set in the agent's environment)
DELIBERATE_SERVER_URL=http://localhost:4000
DELIBERATE_API_KEY=
DELIBERATE_UI_URL=http://localhost:3000

# Agent-Friendly Config (M5)
SEED_FROM_YAML=true
ADMIN_BOOTSTRAP_KEY=
